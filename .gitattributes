# Auto detect text files and perform LF normalization
* text=auto

# Go source files
*.go text eol=lf

# Configuration files
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Markdown files
*.md text eol=lf

# Shell scripts (should always use LF)
*.sh text eol=lf
*.bat text eol=crlf

# Makefiles
Makefile text eol=lf

# XML/XAML files
*.xml text eol=lf
*.xaml text eol=lf

# C# source files
*.cs text eol=lf
*.csproj text eol=lf

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Documentation
*.txt text eol=lf
*.rst text eol=lf

# Exclude binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.h5 binary
*.pkl binary
*.csv binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf
.gitmodules text eol=lf

# License files
LICENSE* text eol=lf
COPYING* text eol=lf

