{
  "schema": 2,
  "module": {
    "name": "cloak-client",
    "version": "0.1.0",
    "description": "Cloak client (cbeuw/Cloak) — obfuscator, local TCP listener for chaining (reference manifest)",
    "lang": "binary",
    "platforms": ["linux-x86_64", "windows-x86_64"],
    "wiraid_id": "cloak-client",
    "peer": { "id": "cloak-server" }
  },
  "capabilities": { "transport": true },
  "runtime": {
    "cmd": [
      "{binary}",
      "-c", "{config_path}",
      "-l", "{listen_host}:{listen_port}",
      "-s", "{params.server_host}:{params.server_port}"
    ],
    "config_template": "{\n  \"Transport\": \"direct\",\n  \"ProxyMethod\": \"shadowsocks\",\n  \"EncryptionMethod\": \"plain\",\n  \"UID\": \"{params.uid}\",\n  \"PublicKey\": \"{params.public_key}\",\n  \"ServerName\": \"{params.server_name}\",\n  \"NumConn\": 4,\n  \"BrowserSig\": \"chrome\",\n  \"StreamTimeout\": 300\n}\n",
    "config_path": "ckclient.json",
    "protocol": "tcp",
    "port_discovery": { "mode": "fixed" },
    "ready_signal": { "mode": "tcp_connect", "timeout_ms": 5000 }
  },
  "params_schema": {
    "server_host": { "type": "string", "required": true },
    "server_port": { "type": "string", "required": true },
    "uid": { "type": "string", "required": true },
    "public_key": { "type": "string", "required": true },
    "server_name": { "type": "string", "required": true }
  }
}
