{
  "schema": 2,
  "module": {
    "name": "naive-client",
    "version": "0.1.0",
    "description": "naiveproxy client (klzgrad/naiveproxy)",
    "lang": "binary",
    "platforms": ["linux-x86_64", "windows-x86_64"],
    "wiraid_id": "naiveproxy-client",
    "peer": { "id": "naiveproxy-server" },
    "uri": {
      "schemes": ["naive+https", "naive+quic", "naive+http"],
      "style": "url",
      "scheme_to": "transport",
      "userinfo_user_to": "username",
      "userinfo_pass_to": "password",
      "host_to": "server_host",
      "port_to": "server_port",
      "fragment_to": "remark"
    }
  },
  "capabilities": { "transport": true },
  "runtime": {
    "cmd": ["{binary}", "{config_path}"],
    "config_template": "{\n  \"listen\": \"socks://{listen_host}:{listen_port}\",\n  \"proxy\": \"{params.transport}://{params.username}:{params.password}@{params.server_host}:{params.server_port}\"\n}",
    "config_path": "config.json",
    "protocol": "socks5",
    "port_discovery": { "mode": "fixed" },
    "ready_signal": { "mode": "tcp_connect", "timeout_ms": 5000 }
  },
  "params_schema": {
    "transport":   { "type": "string", "required": true },
    "username":    { "type": "string", "required": true },
    "password":    { "type": "string", "required": true },
    "server_host": { "type": "string", "required": true },
    "server_port": { "type": "string", "required": true }
  }
}
