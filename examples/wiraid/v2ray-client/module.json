{
  "schema": 2,
  "module": {
    "name": "v2ray-client",
    "version": "0.1.0",
    "description": "v2ray-core client (v2fly) — VMess+WS+TLS",
    "lang": "binary",
    "platforms": ["linux-x86_64", "windows-x86_64"],
    "wiraid_id": "v2ray-client",
    "peer": { "id": "v2ray-server" },
    "uri": {
      "schemes": ["vmess"],
      "style": "base64_json",
      "fragment_to": "remark",
      "json_map": {
        "add":  "server_host",
        "port": "server_port",
        "id":   "uuid",
        "path": "path",
        "host": "sni",
        "net":  "network",
        "tls":  "security",
        "ps":   "remark"
      }
    }
  },
  "capabilities": { "transport": true },
  "runtime": {
    "cmd": ["{binary}", "run", "-c", "{config_path}"],
    "config_template": "{\n  \"log\": { \"loglevel\": \"warning\" },\n  \"inbounds\": [{\n    \"listen\": \"{listen_host}\",\n    \"port\": {listen_port},\n    \"protocol\": \"socks\",\n    \"settings\": { \"auth\": \"noauth\", \"udp\": true }\n  }],\n  \"outbounds\": [{\n    \"protocol\": \"vmess\",\n    \"settings\": {\n      \"vnext\": [{\n        \"address\": \"{params.server_host}\",\n        \"port\": {params.server_port},\n        \"users\": [{ \"id\": \"{params.uuid}\", \"alterId\": 0 }]\n      }]\n    },\n    \"streamSettings\": {\n      \"network\": \"ws\",\n      \"security\": \"tls\",\n      \"tlsSettings\": { \"serverName\": \"{params.sni}\", \"allowInsecure\": true },\n      \"wsSettings\": { \"path\": \"{params.path}\" }\n    }\n  }]\n}\n",
    "config_path": "config.json",
    "protocol": "socks5",
    "port_discovery": { "mode": "fixed" },
    "ready_signal": { "mode": "tcp_connect", "timeout_ms": 5000 }
  },
  "params_schema": {
    "server_host": { "type": "string", "required": true },
    "server_port": { "type": "string", "required": true },
    "uuid":        { "type": "string", "required": true },
    "path":        { "type": "string", "required": true },
    "sni":         { "type": "string", "required": true }
  }
}
