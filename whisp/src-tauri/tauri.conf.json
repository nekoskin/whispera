{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/mihomo",
      "binaries/whispera-go-client"
    ],
    "resources": {
      "whispera-ml-server.exe": "whispera-ml-server.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "Whisp",
  "mainBinaryName": "Whisp",
  "version": "0.1.5",
  "identifier": "com.whispera.whisp",
  "plugins": {},
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Whisp",
        "width": 1200,
        "height": 600,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}