{
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devPath": "http://localhost:1420",
        "distDir": "../dist",
        "withGlobalTauri": true
    },
    "package": {
        "productName": "whispera-client",
        "version": "0.1.1"
    },
    "tauri": {
        "allowlist": {
            "all": true,
            "shell": {
                "all": true,
                "open": true,
                "sidecar": true
            }
        },
        "bundle": {
            "active": true,
            "targets": "all",
            "identifier": "com.whispera.client",
            "icon": [
                "icons/app-icon.ico"
            ],
            "externalBin": [
                "bin/whispera-go-client",
                "bin/mihomo"
            ]
        },
        "security": {
            "csp": null
        },
        "windows": [
            {
                "fullscreen": false,
                "height": 600,
                "resizable": true,
                "title": "Whispera VPN",
                "width": 800
            }
        ]
    }
}