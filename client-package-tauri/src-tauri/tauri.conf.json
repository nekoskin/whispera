{
    "build": {
        "beforeDevCommand": "",
        "beforeBuildCommand": "",
        "devPath": "../ui",
        "distDir": "../ui",
        "withGlobalTauri": true
    },
    "package": {
        "productName": "Whispera",
        "version": "0.1.0"
    },
    "tauri": {
        "allowlist": {
            "all": false,
            "shell": {
                "all": false,
                "open": true,
                "sidecar": true,
                "scope": [
                    {
                        "name": "bin/whispera-go-client",
                        "sidecar": true
                    }
                ]
            },
            "window": {
                "all": true
            }
        },
        "bundle": {
            "active": true,
            "category": "Utility",
            "copyright": "",
            "deb": {
                "depends": []
            },
            "externalBin": [
                "bin/whispera-go-client"
            ],
            "resources": [
                "bin/hev-socks5-tunnel.exe",
                "bin/wintun.dll",
                "bin/hev-config.yml"
            ],
            "icon": [],
            "identifier": "com.whispera.client",
            "longDescription": "",
            "macOS": {
                "entitlements": null,
                "exceptionDomain": "",
                "frameworks": [],
                "providerShortName": null,
                "signingIdentity": null
            },
            "shortDescription": "",
            "targets": "all",
            "windows": {
                "certificateThumbprint": null,
                "digestAlgorithm": "sha256",
                "timestampUrl": ""
            }
        },
        "security": {
            "csp": null
        },
        "updater": {
            "active": false
        },
        "windows": [
            {
                "fullscreen": false,
                "height": 800,
                "resizable": true,
                "title": "Whispera VPN",
                "width": 1200
            }
        ]
    }
}